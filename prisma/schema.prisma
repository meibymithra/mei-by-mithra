generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BookingStatus {
  BOOKED
  COMPLETED
  CANCELLED
  PENDING
}

enum InvoiceStatus {
  PENDING
  PAID
  VOID
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum FeedbackPublishStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EmailStatus {
  QUEUED
  SENT
  FAILED
  MOCKED
}

enum ProductPaymentProvider {
  RAZORPAY
  STRIPE
  MANUAL
}

enum CalendlyWebhookStatus {
  RECEIVED
  PROCESSED
  DUPLICATE
  FAILED
}

model AdminUser {
  id             String   @id @default(uuid()) @db.Uuid
  supabaseUserId String   @unique
  name           String
  email          String   @unique
  recoveryEmail  String?
  passwordHash   String?
  role           String   @default("ADMIN")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdClients Client[] @relation("ClientCreatedBy")
  invoices       Invoice[]
}

model Client {
  id              String        @id @default(uuid()) @db.Uuid
  fullName        String
  email           String        @unique
  phone           String        @unique
  age             Int?
  emergencyName   String?
  emergencyPhone  String?
  concernSummary  String?
  goals           Json?
  priorExperience Boolean?      @default(false)
  sessionCredits  Int           @default(0)
  notes           String        @default("")
  tags            String[]      @default([])
  createdByAdminId String?       @db.Uuid
  createdByAdmin  AdminUser?    @relation("ClientCreatedBy", fields: [createdByAdminId], references: [id])
  intakeForms     IntakeForm[]
  bookings        Booking[]
  invoices        Invoice[]
  feedbacks       Feedback[]
  testimonials    Testimonial[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([createdByAdminId])
}

model IntakeForm {
  id                        String   @id @default(uuid()) @db.Uuid
  bookingId                 String?  @unique @db.Uuid
  clientId                  String   @db.Uuid
  fullName                  String
  age                       Int
  phone                     String
  email                     String
  emergencyContactName      String
  emergencyContactPhone     String
  concern                   String
  goals                     Json
  goalsNote                 String?
  priorExperience           Boolean  @default(false)
  priorExperienceDetails    String?
  confidentialityAccepted   Boolean  @default(false)
  termsAccepted             Boolean  @default(false)
  submittedAt               DateTime @default(now())
  client                    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  booking                   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([clientId])
}

model Booking {
  id                String      @id @default(uuid()) @db.Uuid
  clientId          String      @db.Uuid
  calendlyEventUri   String?     @unique
  calendlyInviteUri  String?
  scheduledAt       DateTime?
  timezone          String?
  status            BookingStatus @default(PENDING)
  rescheduleNote    String?
  intakeToken       String      @unique
  feedbackToken     String      @unique
  sessionType      String      @default("single")
  client           Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  intakeForms      IntakeForm[]
  invoices         Invoice[]
  payments         Payment[]
  feedbacks        Feedback[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([clientId, status])
}

model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  clientId       String        @db.Uuid
  bookingId      String?       @db.Uuid
  adminId        String?       @db.Uuid
  sessionCount   Int
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("INR")
  paymentLink    String?
  status         InvoiceStatus @default(PENDING)
  notes          String        @default("")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  booking        Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  admin          AdminUser?    @relation(fields: [adminId], references: [id], onDelete: SetNull)
  payment        Payment?

  @@index([clientId, status])
  @@index([bookingId])
  @@index([adminId])
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  invoiceId       String        @unique @db.Uuid
  bookingId       String?       @db.Uuid
  provider        ProductPaymentProvider @default(MANUAL)
  providerRef     String?
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("INR")
  status          PaymentStatus @default(PENDING)
  receivedAt      DateTime?
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  booking         Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([bookingId])
}

model Feedback {
  id                  String               @id @default(uuid()) @db.Uuid
  clientId            String               @db.Uuid
  bookingId           String?              @db.Uuid
  token               String               @unique
  rating              Int
  feedback            String
  consentToTestimonial Boolean              @default(false)
  publishStatus       FeedbackPublishStatus @default(PENDING)
  submittedAt        DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  client             Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  booking            Booking?             @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  testimonial        Testimonial?         @relation("FeedbackToTestimonial")

  @@index([clientId, publishStatus])
  @@index([bookingId])
}

model Testimonial {
  id          String   @id @default(uuid()) @db.Uuid
  clientId    String   @db.Uuid
  feedbackId  String?   @unique @db.Uuid
  name        String
  quote       String
  rating      Int
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  feedback    Feedback? @relation("FeedbackToTestimonial", fields: [feedbackId], references: [id], onDelete: SetNull)

  @@index([clientId])
}

model Product {
  id           String                  @id @default(uuid()) @db.Uuid
  slug         String                  @unique
  name         String
  description  String
  price        Decimal                 @db.Decimal(12, 2)
  currency     String                  @default("INR")
  downloadUrl  String?
  paymentLink  String?
  provider     ProductPaymentProvider  @default(MANUAL)
  active       Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
}

model EmailLog {
  id                String      @id @default(uuid()) @db.Uuid
  to                String
  subject           String
  templateKey       String
  providerMessageId String?
  status            EmailStatus @default(QUEUED)
  metadata          Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([templateKey, status])
}

model EmailTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  subject   String
  body      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteContent {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  title     String
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CalendlyWebhookLog {
  id           String                @id @default(uuid()) @db.Uuid
  eventKey     String                @unique
  eventType    String
  eventUri     String?
  inviteeUri   String?
  inviteeEmail String?
  inviteeName  String?
  scheduledAt  DateTime?
  status       CalendlyWebhookStatus @default(RECEIVED)
  notes        String                @default("")
  payload      Json
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([eventType, status])
  @@index([inviteeEmail])
}
